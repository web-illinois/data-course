@page "/credential/relatedlinks"
@layout SidebarLayout

<PageTitle>Credentials - Related Links Information</PageTitle>

<ilw-content>
    <h1>Related Links Information</h1>
    <p>This allows you to generate a list of related links for the credential. This will be displayed on the credential page.</p>
    @if (!string.IsNullOrWhiteSpace(Instructions)) {
        <h2>Instructions</h2>
        <p>@Instructions</p>
    }
</ilw-content>

@if (CredentialItem != null && UseItem) {
    <LinkList @ref="_linkList" Links="@CredentialItem.LinkList?.ToList()"></LinkList>
    <button class="ilw-button ilw-theme-orange-solid" @onclick="Save" @onblur="Layout.RemoveMessage">Save</button>
    <ViewLink Title="Credential" Url="@CredentialItem.UrlFull"></ViewLink>
} else if (!UseItem) {
    <ilw-content><p>Related Links are not currently being used for this source. You can enable this in the <a href="/configuration/fieldsused/credentials">Fields Used</a> section.</p></ilw-content>
}