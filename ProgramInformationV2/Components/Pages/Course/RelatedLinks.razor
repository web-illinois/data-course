@page "/course/relatedlinks"
@layout SidebarLayout

<PageTitle>Course - Related Links Information</PageTitle>

<ilw-content>
    <h1>Related Links Information</h1>
    <p>This allows you to generate a list of related links for the course. This will be displayed on the course page.</p>
    @if (!string.IsNullOrWhiteSpace(Instructions)) {
        <h2>Instructions</h2>
        <p>@Instructions</p>
    }
</ilw-content>

@if (CourseItem != null && UseItem) {
    <LinkList @ref="_linkList" Links="@CourseItem.LinkList?.ToList()"></LinkList>
    <button class="ilw-button ilw-theme-orange-solid" @onclick="Save" @onblur="Layout.RemoveMessage">Save</button>
    <ViewLink Title="Course" Url="@CourseItem.UrlFull"></ViewLink>
} else if (!UseItem) {
    <ilw-content><p>Related Links are not currently being used for this source. You can enable this in the <a href="/configuration/fieldsused/courses">Fields Used</a> section.</p></ilw-content>
}